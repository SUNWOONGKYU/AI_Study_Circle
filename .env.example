# WAAT 환경변수 템플릿 (실제 .env 파일은 .gitignore로 제외됨)
# 사용법: 이 파일을 .env로 복사한 후 실제 값으로 채우기

# Resend 이메일 발송
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=WAAT 운영자
RESEND_REPLY_TO=admin@example.com

# 알리고 SMS/알림톡
ALIGO_USER_ID=
ALIGO_API_KEY=
ALIGO_SENDER=

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PROJECT_REF=xxxxxxxxxxxx
